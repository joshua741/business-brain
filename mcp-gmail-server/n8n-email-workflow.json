    {
      "id": "flatten-emails",
      "name": "Flatten Emails",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300],
      "parameters": {
        "jsCode": "// Collect all emails from both inputs with their account tag\nconst emails = [];\nfor (const item of $input.all()) {\n  const messages = item.json.messages || [];\n  const account = messages.length > 0 && item.json.account_email\n    ? (item.json.account_email.includes('docs') ? 'docs' : 'joshua')\n    : 'joshua';\n  for (const msg of messages) {\n    emails.push({ json: { ...msg, account } });\n  }\n}\nif (emails.length === 0) {\n  // Return a sentinel so downstream nodes know there's nothing to do\n  return [{ json: { _empty: true, count: 0 } }];\n}\nreturn emails;"
      }
    },
    {
