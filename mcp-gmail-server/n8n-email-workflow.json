      "id": "get-full-email",
      "name": "Get Full Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1320, 300],
      "parameters": {
        "method": "GET",
        "url": "=https://business-brain-production-0820.up.railway.app/api/email/{{ $json.message_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "wih-rest-n8n-2026" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
