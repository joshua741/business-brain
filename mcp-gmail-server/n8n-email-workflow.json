          ]
        }
      }
    },
    {
      "id": "claude-classify",
      "name": "Claude Classify",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1540, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 256,\n  \"system\": \"You are an email classifier for a real estate investment business. Classify incoming emails with one of these actions and respond ONLY with a JSON object.\\n\\nActions:\\n- archive: newsletters, automated notifications, marketing, receipts, shipping updates, social media digests, no reply required\\n- needs_review: tenant communications, vendor quotes, non-urgent business emails, general inquiries\\n- urgent: lease issues, maintenance emergencies, legal notices, eviction-related, payment disputes, time-sensitive deadlines within 48 hours\\n- escalate: anything requiring immediate human decision, threats, legal action, lender/investor issues, anything that could cost >$1000 if ignored\\n\\nRespond ONLY with this JSON (no other text):\\n{\\\"action\\\": \\\"<action>\\\", \\\"reason\\\": \\\"<10 word max reason>\\\"}\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"From: {{ $json.from }}\\nSubject: {{ $json.subject }}\\nDate: {{ $json.date }}\\n\\n{{ $json.body.substring(0, 1500) }}\"\n    }\n  ]\n}"
      }
    },
    {
      "id": "parse-classification",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1760, 300],
      "parameters": {
        "jsCode": "const item = $input.first();\nconst content = item.json.content?.[0]?.text || '{\"action\":\"needs_review\",\"reason\":\"parse error\"}';\nlet classification;\ntry {\n  classification = JSON.parse(content);\n} catch (e) {\n  // Try to extract JSON from the response\n  const match = content.match(/\\{[^}]+\\}/);\n  classification = match ? JSON.parse(match[0]) : { action: 'needs_review', reason: 'parse error' };\n}\n// Pass through email metadata from the get-full-email step\nconst emailData = $('Get Full Email').first().json;\nreturn [{\n  json: {\n    ...emailData,\n    account: $('Loop Emails').first().json.account,\n    action: classification.action || 'needs_review',\n    reason: classification.reason || '',\n  }\n}];"
      }
    },
