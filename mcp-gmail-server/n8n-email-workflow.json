    {
      "id": "claude-classify",
      "name": "Claude Classify",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1100, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "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" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "={{ JSON.stringify({ model: 'claude-haiku-4-5-20251001', max_tokens: 256, system: 'You are an email classifier for a real estate investment business. Classify incoming emails with one of these actions and respond ONLY with a JSON object.\\n\\nActions:\\n- archive: newsletters, automated notifications, marketing, receipts, shipping updates, social media digests, no reply required\\n- needs_review: tenant communications, vendor quotes, non-urgent business emails, general inquiries\\n- urgent: lease issues, maintenance emergencies, legal notices, eviction-related, payment disputes, time-sensitive deadlines within 48 hours\\n- escalate: anything requiring immediate human decision, threats, legal action, lender/investor issues, anything that could cost >$1000 if ignored\\n\\nRespond ONLY with this JSON (no other text):\\n{\"action\": \"<action>\", \"reason\": \"<10 word max reason>\"}', messages: [{ role: 'user', content: 'From: ' + $json.from + '\\nSubject: ' + $json.subject + '\\nDate: ' + $json.date + '\\n\\n' + ($json.body ? $json.body.substring(0, 1500) : ($json.snippet || '')) }] }) }}"
      }
    },
    {
      "id": "parse-classification",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 300],
      "parameters": {
        "jsCode": "const results = [];\nconst claudeItems = $input.all();\nconst emailItems = $('Get Full Email').all();\n\nfor (let i = 0; i < claudeItems.length; i++) {\n  const claudeItem = claudeItems[i];\n  const emailItem = emailItems[i] || emailItems[0];\n  const content = claudeItem.json.content?.[0]?.text || '{\"action\":\"needs_review\",\"reason\":\"parse error\"}';\n  let classification;\n  try {\n    classification = JSON.parse(content);\n  } catch (e) {\n    const match = content.match(/\\{[^}]+\\}/);\n    classification = match ? JSON.parse(match[0]) : { action: 'needs_review', reason: 'parse error' };\n  }\n  results.push({\n    json: {\n      ...emailItem.json,\n      action: classification.action || 'needs_review',\n      reason: classification.reason || '',\n    }\n  });\n}\nreturn results;"
      }
    },
