    {
      "id": "flatten-emails",
      "name": "Flatten Emails",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300],
      "parameters": {
        "jsCode": "const emails = [];\nfor (const item of $input.all()) {\n  const messages = item.json.messages || [];\n  const account = item.json.account_email\n    ? (item.json.account_email.includes('docs') ? 'docs' : 'joshua')\n    : 'joshua';\n  for (const msg of messages) {\n    emails.push({ json: { ...msg, account } });\n  }\n}\nreturn emails;"
      }
    },
