# Business Brain connector credentials. Copy this file to ".env" (gitignored) and fill in.
# Never commit .env.

# --- GHL (GoHighLevel) ---
# Create a Private Integration Token: GHL > Settings > Private Integrations > New
#   scopes (read): contacts.readonly, opportunities.readonly, locations/pipelines.readonly
# Location ID: GHL > Settings > Business Profile (or the sub-account id in the URL).
GHL_API_TOKEN=
GHL_LOCATION_ID=
